fn main(args:list[string]) {
  var_test();
  list_test($args);
  arg_count("foo" "bar" "baz quz");
  block_test();
  list_literal();
}

arg_count: {
  print("arg count:" $[count]);
}

block_test: {
  {}
  {
    print("block test");
  }
}

fn list_test(foo:list[string]) {
    print("passing list directly: " $foo);

    print("keyword splat ([,,] and [splat]):");
    arg_count("keyword splat:" $foo[splat]);
    arg_count("symbol splat:" $foo[,,]);

    print("indexing:" $foo[0]);
}

fn list_literal() {
  print("list literal" .[ "foo" "bar" "baz" ]);
  arg_count("list literal" .[ "foo" "bar" "baz" ]);
}

fn var_test() {
  set foo = "bar";
  let baz = "qux";
  print($foo $baz);
}
