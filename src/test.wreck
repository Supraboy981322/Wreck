#!/usr/bin/env wreck
$printf("\e[33mfoo\e[0m '%d' \" \n" 1);

$curl([[ f silent S L ]] #(some comment between) 'https://archive.google/heart');

#(comment with an escaped \))

if (1 == 0) {
  #(nested #(comments #(work)))
  $printf("1 EQUALS 0? WHAT?\n");
} else {
  $printf("1 does not equal 0\n");
}

? (1 > 0) {
  #(nested #(comments #(work)))
  $printf("1 is greater-than 0\n");
} ?! {
  $printf("1 ISN'T GREATER THAN 0?\n");
}

#(fn main() bool {
  $printf("foo\n");
  #(@std.printf("foo\n");)
